{
  "manifest_version": 2,
  "name": "ChromeGPT",
  "version": "1.0",
  "description": "A local-first Chrome extension for AI form assistance using Ollama.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ],
  "background": {
    "service_worker": "backgroundServiceWorker.js"
  },
  "permissions": [
    "activeTab",
    "tab",
    "storage"
  ]
}