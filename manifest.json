{
  "manifest_version": 3,
  "name": "ChromeGPT",
  "version": "1.0",
  "description": "A local-first Chrome extension for AI form assistance using Ollama.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ],
  "background": {
    "service_worker": "backgroundServiceWorker.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs", // Add the missing permission
    "https://cdn.jsdelivr.net/npm/ollama@2.5.3/dist/" // Add this line to allow access to Ollama CDN
  ]
}