{
  "name": "ChromeGPT",
  "version": "1.0.0",
  "description": "A local-first Chrome extension for AI form assistance using Ollama.",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/ai_form_assistant_icon.png",
      "48": "icons/ai_form_assistant_icon.png",
      "96": "icons/ai_form_assistant_icon.png",
      "128": "icons/ai_form_assistant_icon.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "configuration.html"
}
